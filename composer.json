{
    "name": "nexus-actors/doctrine-dbal",
    "description": "Nexus Doctrine DBAL — coroutine-aware connection pool and actor-side integration (HTTP middleware lives in nexus-actors/doctrine-dbal-http).",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.5.7",
        "doctrine/dbal": "^4.0",
        "nexus-actors/core": "^0.1",
        "nexus-actors/runtime": "^0.1",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Monadial\\Nexus\\Doctrine\\Dbal\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Monadial\\Nexus\\Doctrine\\Dbal\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
